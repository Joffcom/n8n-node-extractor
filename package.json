{
  "name": "n8n-node-extractor",
  "version": "1.0.2",
  "description": "Tool to extract node metadata from n8n packages without installing them",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
